<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="com.poplingo.poplingo.HelloController" styleClass="root">

    <!-- 1. 登入頁面 -->
    <VBox fx:id="pageLogin" alignment="CENTER" spacing="25.0">
        <VBox alignment="CENTER" spacing="2.0">
            <Label text="Poplingo" styleClass="title-label"/>
            <Label text="從音樂中聽見世界" styleClass="subtitle-text"/>
        </VBox>
        <Button text="開始學習" onAction="#onLoginClick" prefHeight="50.0" prefWidth="260.0" styleClass="login-button"/>
    </VBox>

    <!-- 2. 選擇頁面 (國家/歌手/歌曲共用) -->
    <VBox fx:id="pageSelection" visible="false" alignment="TOP_CENTER" spacing="20.0" style="-fx-padding: 40 20 20 20;">
        <HBox alignment="CENTER_LEFT" maxWidth="300">
            <Button text="←" onAction="#onBackClick" style="-fx-background-color: transparent; -fx-text-fill: #4A4E69; -fx-font-size: 24; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <Label fx:id="selectionTitle" text="選擇類別" styleClass="title-label" style="-fx-font-size: 28;"/>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="NEVER">
            <VBox fx:id="listContainer" spacing="15.0" alignment="CENTER" />
        </ScrollPane>
    </VBox>

    <!-- 3. 學習頁面 (進度條 + TextFlow 完全體) -->
    <VBox fx:id="pageLearn" visible="false" alignment="TOP_CENTER" spacing="15.0" style="-fx-padding: 20;">
        <HBox alignment="CENTER_LEFT">
            <Button text="←" onAction="#onBackClick" style="-fx-background-color: transparent; -fx-text-fill: #4A4E69; -fx-font-size: 24; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="learnTitle" text="學習中..." styleClass="subtitle-text"/>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <Button fx:id="playButton" text="▶ 播放音樂" onAction="#onPlayMusicClick" styleClass="login-button" prefWidth="200" prefHeight="40" style="-fx-font-size: 16px;"/>

        <!-- 🌟 補回來的：音樂進度條與時間顯示 -->
        <HBox alignment="CENTER" spacing="10" maxWidth="300">
            <Label fx:id="currentTimeLabel" text="00:00" style="-fx-text-fill: #7F7F9D; -fx-font-weight: bold;"/>
            <Slider fx:id="progressBar" HBox.hgrow="ALWAYS" styleClass="music-slider"/>
            <Label fx:id="totalTimeLabel" text="00:00" style="-fx-text-fill: #7F7F9D; -fx-font-weight: bold;"/>
        </HBox>

        <!-- 單字顯示區域 -->
        <VBox styleClass="flashcard" maxWidth="320" spacing="8" alignment="CENTER">
            <Label fx:id="wordLabel" text="請點擊下方歌詞" styleClass="flashcard-word" style="-fx-font-size: 24;"/>
            <Label fx:id="phoneticLabel" text="點擊單字查詢翻譯" styleClass="flashcard-phonetic"/>
            <Label fx:id="translationLabel" text="-" styleClass="flashcard-translation"/>
            <Label fx:id="lyricLabel" text="-" styleClass="flashcard-lyric"/>
        </VBox>

        <!-- 升級版：可點擊歌詞區 -->
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" prefHeight="260" vbarPolicy="NEVER">
            <TextFlow fx:id="lyricsTextFlow" textAlignment="CENTER" style="-fx-padding: 10;" />
        </ScrollPane>
    </VBox>

</StackPane>